{
  "name": "my-app-connector",
  "version": "1.0.0",
  "description": "Connect OpenClaw agent to your custom app via WebSocket",
  "runtime": "node",
  "entry": "connector.js",
  "config": {
    "agentName": "Deciple1",
    "appEndpoint": "ws://localhost:3000/openclaw",
    "reconnectInterval": 5000,
    "heartbeatInterval": 30000
  }
}
